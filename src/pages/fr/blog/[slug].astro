---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog-fr');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} lang="fr">
  <header class="mb-10">
    <p class="text-xs text-neutral-400 mb-2">[{post.data.date.toISOString().slice(0, 10)}]</p>
    <h1 class="text-xl font-bold text-neutral-900 dark:text-neutral-100 leading-snug mb-3">
      {post.data.title}
    </h1>
    <div class="flex flex-wrap gap-2">
      {post.data.tags.map(tag => (
        <span class="text-xs border border-neutral-300 dark:border-neutral-700 px-2 py-0.5 text-neutral-500">
          #{tag}
        </span>
      ))}
    </div>
  </header>

  <article class="prose prose-neutral dark:prose-invert prose-sm max-w-none">
    <Content />
  </article>
</BaseLayout>
